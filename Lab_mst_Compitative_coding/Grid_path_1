#include <bits/stdc++.h>

using namespace std;


class solution {
public:
    int gridPath(vector<vector<int>>& grid) {
        int m = grid.size();
        int n = grid[0].size();
        vector<vector<int>> dp(m, vector<int>(n, 0));

        for (int i = 0; i < m; i++) {
            dp[i][0] = 1;
            if (grid[i][0] == 1) {
                dp[i][0] = 0;
            }
        }

        for (int j = 0; j < n; j++) {
            dp[0][j] = 1;
            if (grid[0][j] == 1) {
                dp[0][j] = 0;
            }
        }

        for (int i = 1; i < m; i++) {
            for (int j = 1; j < n; j++) {
                if (grid[i][j] == 1) {
                    dp[i][j] = 0;
                } else {
                    dp[i][j] = dp[i - 1][j] + dp[i][j - 1];
                }
            }
        }

        return dp[m - 1][n - 1];
    }
};


int main() {
    solution sol;
    vector<vector<int>> grid = {
        {0, 0, 0},
        {0, 1, 0},
        {0, 0, 0}
    };
    cout << sol.gridPath(grid) << endl; // Output: 2  
    return 0;
}